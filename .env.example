NODE_ENV=development

APP_PORT=3001
APP_JWT_SECRET=your-secret-key

# Optional: app metadata (used in email templates)
APP_NAME=Intellysys
DASHBOARD_URL=http://localhost:5173

# Database
# DATABASE_URL=postgresql://postgres:password@localhost:5432/intellysys_db

# Email (SMTP) - leave EMAIL_ENABLED=false to disable sending
EMAIL_ENABLED=false
EMAIL_INCLUDE_PASSWORD=false
EMAIL_SUPPORT=support@your-domain.com

SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Intellysys <no-reply@your-domain.com>"

