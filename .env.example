NODE_ENV=development

APP_PORT=3001
APP_JWT_SECRET=your-secret-key

# Optional: app metadata (used in email templates)
APP_NAME=Intellysys
DASHBOARD_URL=http://localhost:5173

# Database
# DATABASE_URL=postgresql://postgres:password@localhost:5432/intellysys_db

# Email (SMTP) - leave EMAIL_ENABLED=false to disable sending
EMAIL_ENABLED=false
EMAIL_INCLUDE_PASSWORD=false
EMAIL_SUPPORT=system.noreply@wapintellysys.it.com

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
# MailHog doesn't require auth
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM="Intellysys App <system.noreply@wapintellysys.it.com>"

